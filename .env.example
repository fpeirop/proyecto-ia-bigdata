# ==============================================================================
# SmartTrafficFlow AI — Variables de entorno
# Copia este fichero a .env y rellena los valores reales
# El fichero .env NUNCA se sube al repositorio
# ==============================================================================

# ------------------------------------------------------------------------------
# Rutas de datos
# ------------------------------------------------------------------------------
DATA_RAW_PATH=data/raw/
DATA_PROCESSED_PATH=data/processed/
DATA_PREDICTIONS_PATH=data/predictions/

# ------------------------------------------------------------------------------
# Configuración del modelo
# ------------------------------------------------------------------------------
MODEL_OUTPUT_PATH=models/
PREDICTION_HORIZON_MINUTES=30       # Opciones: 30 o 60
N_SENSORS=300                       # Subset de sensores a usar (300 o 554)

# ------------------------------------------------------------------------------
# Streamlit
# ------------------------------------------------------------------------------
STREAMLIT_PORT=8501

# ------------------------------------------------------------------------------
# MLflow (tracking de experimentos — opcional en fase inicial)
# ------------------------------------------------------------------------------
MLFLOW_TRACKING_URI=mlruns/
MLFLOW_EXPERIMENT_NAME=smarttrafficflow-baseline
