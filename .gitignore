# ==============================================================================
# SmartTrafficFlow AI — .gitignore
# ==============================================================================

# ------------------------------------------------------------------------------
# Python
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/

# ------------------------------------------------------------------------------
# Entornos virtuales
# ------------------------------------------------------------------------------
venv/
.venv/
env/
ENV/
.env/

# ------------------------------------------------------------------------------
# Variables de entorno (¡NUNCA subir!)
# ------------------------------------------------------------------------------
.env
.env.local
.env.production
*.env

# ------------------------------------------------------------------------------
# Datos (el dataset no se sube a Git — usar DVC o descarga manual)
# ------------------------------------------------------------------------------
data/raw/
data/processed/
data/predictions/
*.csv
*.parquet
*.h5
*.hdf5
*.npy
*.npz
*.pkl
*.pickle

# Excepciones: sí subimos los ficheros de muestra pequeños en data/samples/
!data/samples/

# ------------------------------------------------------------------------------
# Modelos entrenados
# ------------------------------------------------------------------------------
models/
*.joblib
*.model
mlruns/
mlflow.db

# ------------------------------------------------------------------------------
# Jupyter Notebooks — checkpoints
# ------------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# ------------------------------------------------------------------------------
# Tests y cobertura
# ------------------------------------------------------------------------------
.pytest_cache/
htmlcov/
.coverage
coverage.xml
*.cover

# ------------------------------------------------------------------------------
# Herramientas de desarrollo
# ------------------------------------------------------------------------------
.ruff_cache/
.mypy_cache/
.dmypy.json
dmypy.json

# ------------------------------------------------------------------------------
# IDEs y editores
# ------------------------------------------------------------------------------
# VS Code
.vscode/
*.code-workspace

# PyCharm
.idea/

# Jupyter
.jupyter/

# ------------------------------------------------------------------------------
# Sistema operativo — Windows
# ------------------------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Sistema operativo — macOS
.DS_Store
.AppleDouble
.LSOverride

# Sistema operativo — Linux
*~

# ------------------------------------------------------------------------------
# Logs y temporales
# ------------------------------------------------------------------------------
*.log
logs/
tmp/
temp/
